#include <iostream>

using namespace std;

int main() {
    int firstNumber, secondNumber;
    int sum, subtraction;
    double multiplication, division;
    
    cout << "Digite um numero: \n";
    cin >> firstNumber;
    cout << "Digite um numero: \n";
    cin >> secondNumber;
    
    sum = firstNumber + secondNumber;
    subtraction = firstNumber - secondNumber;
    multiplication = firstNumber * secondNumber;
    division = (double)firstNumber / secondNumber;
    
    cout << "--------------------------------------\n";
    cout << "A soma dos numeros: " << sum << endl;
    cout << "A subtracao dos numeros: " << subtraction << endl;
    cout << "A multiplicacao dos numeros: " << multiplication << endl;
    cout << "A divisao dos numeros: " << division << endl;

    return 0;
}